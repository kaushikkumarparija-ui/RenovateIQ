# ---- Supabase ----
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Project Settings → API → service_role (server-only; used by the seed script)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- LLM providers (free) ----
# Plan generation + what-if run on free, OpenAI-compatible providers. The app
# tries OpenRouter first, then falls back to Groq. Configure at least one;
# both is recommended for resilience when a free tier is rate-limited.

# OpenRouter (primary) — free models (the `:free` suffix). Key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-key
# Optional. Defaults to meta-llama/llama-3.3-70b-instruct:free.
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# Optional. Used only for OpenRouter attribution headers.
OPENROUTER_SITE_URL=https://renovateiq-bice.vercel.app

# Groq (fallback) — free tier. Get a key at https://console.groq.com/keys
GROQ_API_KEY=your-groq-key
# Optional. Defaults to llama-3.3-70b-versatile.
GROQ_MODEL=llama-3.3-70b-versatile
